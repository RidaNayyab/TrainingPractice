// Get transcript
app.get('/api/transcription/:transcriptionId/transcript', async (req: any, res: any) => {
  try {
    const { transcriptionId } = req.params;

    const apiKey = process.env.SONIOX_API_KEY;
    if (!apiKey) {
      return res.status(500).json({ error: 'Soniox API key not configured' });
    }

    const response = await fetch(`${SONIOX_API_BASE_URL}/v1/transcriptions/${transcriptionId}/transcript`, {
      method: 'GET',
      headers: {
        'Authorization': `Bearer ${apiKey}`,
      },
    });

    if (!response.ok) {
      const error = await response.text();
      console.error('❌ Transcript fetch error:', response.status, error);
      return res.status(response.status).json({ error: 'Transcript fetch failed: ' + error });
    }

    const result = await response.json();
    const tokens = result.tokens || [];

    // Convert tokens to readable transcript
    let transcript = '';
    tokens.forEach((token: any) => {
      transcript += token.text;
    });

    res.json({ transcript: transcript.trim() });
  } catch (error: any) {
    console.error('❌ Transcript error:', error);
    res.status(500).json({ error: error.message });
  }
});

