// Get training resources for an indicator (AI-recommended based on feedback)
app.get('/api/indicator/:indicatorCode/training', async (req: Request, res: Response) => {
  try {
    const { indicatorCode } = req.params;
    const { teacherId } = req.query;

    const training = trainingsData[indicatorCode as keyof typeof trainingsData];

    if (!training) {
      return res.status(404).json({ error: 'Training not found for this indicator' });
    }

    // If no teacherId, return all resources (for backwards compatibility)
    if (!teacherId) {
      return res.json(training);
    }

    // Get completed trainings for this teacher+indicator
    const completedResult = await dbClient.query(
      `SELECT resource_index FROM completed_trainings
       WHERE teacher_id = $1 AND indicator_code = $2
       ORDER BY resource_index`,
      [teacherId, indicatorCode]
    );

    const completedIndices = new Set(completedResult.rows.map((r: any) => r.resource_index));

    let nextResourceIndex = 0;
    let isFirstTraining = completedIndices.size === 0;

    if (isFirstTraining) {
      // First training: Use AI to analyze feedback and recommend best training
      const obsResult = await dbClient.query(
        `SELECT feedback_english FROM observation_feedback_loops ofl
         JOIN observations o ON ofl.observation_id = o.id
         WHERE o.teacher_id = $1
         ORDER BY o.created_at DESC
         LIMIT 1`,
        [teacherId]
      );

      if (obsResult.rows.length > 0) {
        const feedback = obsResult.rows[0].feedback_english;
        console.log('📊 Analyzing feedback for teacher', teacherId, 'indicator', indicatorCode);
        nextResourceIndex = await recommendTraining(indicatorCode, feedback);
        console.log('✨ AI recommended training index:', nextResourceIndex);
      }
    } else {
      // Subsequent trainings: Find next uncompleted
      for (let i = 0; i < training.resources.length; i++) {
        if (!completedIndices.has(i)) {
          nextResourceIndex = i;
          break;
        }
      }
    }

    // Check if all completed
    if (nextResourceIndex >= training.resources.length) {
      return res.json({
        ...training,
        resources: [],
        allCompleted: true,
        message: 'All trainings completed for this indicator!'
      });
    }

    // Return only the recommended/next training
    res.json({
      ...training,
      resources: [training.resources[nextResourceIndex]],
      currentResourceIndex: nextResourceIndex,
      totalResources: training.resources.length,
      aiRecommended: isFirstTraining
    });
  } catch (error: any) {
    console.error('Error fetching training:', error);
    res.status(500).json({ error: error.message });
  }
});

