// GET /api/teacher/:teacherId/next-training
// Returns the highest priority flagged indicator with feedback and AI-matched training
app.get('/api/teacher/:teacherId/next-training', async (req: Request, res: Response) => {
  try {
    const { teacherId } = req.params;

    // Get highest priority flagged indicator in unlocked tier
    const flaggedIndicator = await getHighestPriorityIndicator(teacherId);

    if (!flaggedIndicator) {
      return res.json({
        success: false,
        message: 'No flagged indicators requiring training'
      });
    }

    // Get the most recent observation and feedback for this teacher
    const obsResult = await dbClient.query(
      `SELECT o.id, o.transcription, o.created_at, o.subject,
              ofl.feedback_english, ofl.improvement_areas
       FROM observations o
       LEFT JOIN observation_feedback_loops ofl ON o.id = ofl.observation_id
       WHERE o.teacher_id = $1
       ORDER BY o.created_at DESC
       LIMIT 1`,
      [teacherId]
    );

    if (obsResult.rows.length === 0) {
      return res.json({
        success: false,
        message: 'No observations found for this teacher'
      });
    }

    const observation = obsResult.rows[0];

    // Use Claude AI to match feedback to best training
    const matched = await matchFeedbackToTraining(
      observation.feedback_english,
      flaggedIndicator.indicator_code,
      observation.subject
    );

    res.json({
      success: true,
      flaggedIndicator: flaggedIndicator,
      observation: {
        id: observation.id,
        transcription: observation.transcription,
        feedback: observation.feedback_english,
        created_at: observation.created_at,
        subject: observation.subject,
        improvement_areas: observation.improvement_areas
      },
      recommendedTraining: matched.training,
      aiReasoning: matched.reasoning
    });
  } catch (error: any) {
    console.error('Error fetching next training:', error);
    res.status(500).json({ error: error.message });
  }
});

// POST /api/admin/validate-training/:teacherId/:indicatorCode
// Admin endpoint to validate training flow for any teacher and indicator
app.post('/api/admin/validate-training/:teacherId/:indicatorCode', async (req: Request, res: Response) => {
  try {
    const { teacherId, indicatorCode } = req.params;

    // Get teacher tier info
    const currentTier = await getTeacherCurrentTier(teacherId);

    // Get the flagged indicator data
    const flagResult = await dbClient.query(
      `SELECT teacher_id, indicator_code, flag_count, escalation_level, subject
       FROM teacher_indicator_flags
       WHERE teacher_id = $1 AND indicator_code = $2`,
      [teacherId, indicatorCode]
    );

    const flagged = flagResult.rows[0];
    if (!flagged) {
      return res.status(404).json({ error: 'Indicator not flagged for this teacher' });
    }

    // Check if unlocked
    const tierKey = Object.keys(indicatorPriorityMatrix.tiers).find(tier =>
      indicatorPriorityMatrix.tiers[tier as keyof typeof indicatorPriorityMatrix.tiers].indicators?.[indicatorCode]
    );

    const isUnlocked = tierKey ? isTierUnlocked(currentTier, tierKey) : false;

    // Get observation and feedback
    const obsResult = await dbClient.query(
      `SELECT o.id, o.transcription, o.created_at, o.subject,
              ofl.feedback_english, ofl.improvement_areas
       FROM observations o
       LEFT JOIN observation_feedback_loops ofl ON o.id = ofl.observation_id
       WHERE o.teacher_id = $1
       ORDER BY o.created_at DESC
       LIMIT 1`,
      [teacherId]
    );

    const observation = obsResult.rows[0];

    // Get training mapping
    const trainingData = trainingMapping.trainings[indicatorCode as keyof typeof trainingMapping.trainings];

    // Match feedback to training
    let matched: any = { training: null, reasoning: 'No training mapped' };
    if (observation?.feedback_english && trainingData) {
      matched = await matchFeedbackToTraining(
        observation.feedback_english,
        indicatorCode,
        observation.subject
      );
    }

    // Return validation results
    res.json({
      validation: {
        teacherId,
        indicatorCode,
        currentTier,
        indicatorTier: tierKey,
        isTierUnlocked: isUnlocked,
        flagCount: flagged.flag_count,
        escalationLevel: flagged.escalation_level,
        meetsMinimumFlags: flagged.flag_count >= 2
      },
      observation: observation ? {
        id: observation.id,
        transcription: observation.transcription?.substring(0, 100),
        feedback: observation.feedback_english?.substring(0, 200),
        created_at: observation.created_at,
        subject: observation.subject
      } : null,
      trainingRecommendation: {
        indicatorCode,
        trainingTitle: matched.training?.training_title,
        trainingLevel: matched.training?.level,
        trainingUrl: matched.training?.training_url,
        aiReasoning: matched.reasoning
      },
      readyForTraining: isUnlocked && flagged.flag_count >= 2
    });
  } catch (error: any) {
    console.error('Error validating training:', error);
    res.status(500).json({ error: error.message });
  }
});

