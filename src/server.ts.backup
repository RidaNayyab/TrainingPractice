});

// In-memory cache for observations
let observationsCache: any[] = [];
let cacheLoaded = false;

// Helper function to execute queries with a fresh connection
async function queryDB(sql: string, params: any[] = []) {
  const client = new Client({
    host: process.env.PGHOST,
    port: parseInt(process.env.PGPORT || '5432'),
    user: process.env.PGUSER,
    password: process.env.PGPASSWORD,
    database: process.env.PGDATABASE,
  });

  try {
    await client.connect();
    const result = await client.query(sql, params);
    return result;
  } finally {
    await client.end();
  }
}

// ========== HELPER FUNCTIONS ==========

// Get teacher's current tier from tier progression
async function getTeacherCurrentTier(teacherId: string): Promise<string | null> {
  try {
    const result = await dbClient.query(
      `SELECT current_tier FROM teacher_tier_progression
       WHERE teacher_id = $1
       ORDER BY created_at DESC
       LIMIT 1`,
      [teacherId]
    );
    return result.rows.length > 0 ? result.rows[0].current_tier : null;
  } catch (error) {
    console.error('Error getting teacher tier:', error);
    return null;
  }
}

// Check if a tier is unlocked for a teacher
function isTierUnlocked(currentTier: string | null, checkTier: string): boolean {
  if (!currentTier) return true; // If no tier info, assume first tier (unlocked)

  const tierOrder = ['tier_1_structural', 'tier_2_core', 'tier_3_advanced', 'tier_4_subject_specific'];
  const currentIndex = tierOrder.indexOf(currentTier);
  const checkIndex = tierOrder.indexOf(checkTier);

  // Current tier and previous tiers are unlocked
  return checkIndex <= currentIndex;
}

// Get highest priority flagged indicator in unlocked tiers
async function getHighestPriorityIndicator(teacherId: string): Promise<any> {
  try {
    const currentTier = await getTeacherCurrentTier(teacherId);

    // Get all flagged indicators (2+ flags)
    const result = await dbClient.query(
      `SELECT tif.teacher_id, tif.indicator_code, tif.subject, tif.flag_count,
              tif.escalation_level, tif.last_flagged_at
       FROM teacher_indicator_flags tif
       WHERE tif.teacher_id = $1 AND tif.flag_count >= 2
       ORDER BY tif.last_flagged_at DESC`,
      [teacherId]
    );

    const flaggedIndicators = result.rows;

    // Filter by unlocked tiers and get highest priority
    let highestPriority = null;
    let highestPriorityIndicator = null;

    for (const indicator of flaggedIndicators) {
      const indicatorData = indicatorPriorityMatrix.tiers[
        Object.keys(indicatorPriorityMatrix.tiers).find(tier =>
          indicatorPriorityMatrix.tiers[tier as keyof typeof indicatorPriorityMatrix.tiers].indicators?.[indicator.indicator_code]
        ) as keyof typeof indicatorPriorityMatrix.tiers
      ];

      if (!indicatorData) continue;

      const tierKey = Object.keys(indicatorPriorityMatrix.tiers).find(tier =>
        indicatorPriorityMatrix.tiers[tier as keyof typeof indicatorPriorityMatrix.tiers].indicators?.[indicator.indicator_code]
      );

      if (!tierKey || !isTierUnlocked(currentTier, tierKey)) continue;

      const priority = indicatorData.indicators?.[indicator.indicator_code]?.priority_rank;

      if (priority && (!highestPriority || priority < highestPriority)) {
        highestPriority = priority;
        highestPriorityIndicator = { ...indicator, tier: tierKey };
      }
    }

    return highestPriorityIndicator;
  } catch (error) {
    console.error('Error getting highest priority indicator:', error);
    return null;
  }
}

// Match feedback to best training using Claude AI
async function matchFeedbackToTraining(feedback: string, indicatorCode: string, subject?: string): Promise<any> {
  try {
    const trainingData = trainingMapping.trainings[indicatorCode as keyof typeof trainingMapping.trainings];

    if (!trainingData || !trainingData.training_sequence || trainingData.training_sequence.length === 0) {
      return { rank: 1, training: null, reasoning: 'No training mapped' };
    }

    // Filter trainings by subject if applicable
    let trainings = trainingData.training_sequence;
    if (subject) {
      trainings = trainings.filter((t: any) => !t.subject_specific || t.subject_specific === subject ||
        (Array.isArray(t.subject_specific) && t.subject_specific.includes(subject)));
    }

    if (trainings.length === 0) {
      trainings = trainingData.training_sequence.slice(0, 1); // Fallback to first
    }

    // Use Claude to analyze feedback and recommend training
    const trainingOptions = trainings
      .slice(0, 3)
      .map((t: any, i: any) =>
        `${i + 1}. "${t.training_title}" (Level: ${t.level || 'N/A'}): ${t.training_lo}`
      )
      .join('\n');

    const message = await anthropic.messages.create({
      model: 'claude-opus-4-7',
      max_tokens: 500,
      messages: [
        {
          role: 'user',
          content: `Analyze this teacher feedback and recommend the BEST training from the available options.

FEEDBACK: "${feedback}"

INDICATOR: ${indicatorCode}

AVAILABLE TRAININGS (ranked by progression):
${trainingOptions}

Respond in JSON with ONLY these fields:
{
  "recommendedRank": 1 or 2 or 3,
  "reasoning": "Why this training addresses the feedback"
}`
        }
      ]
    });

    const response = message.content[0];
    if (response.type === 'text') {
      const analysis = JSON.parse(response.text);
      const recommendedTraining = trainings[analysis.recommendedRank - 1];
      return { rank: analysis.recommendedRank, training: recommendedTraining, reasoning: analysis.reasoning };
    }

    return { rank: 1, training: trainings[0], reasoning: 'Default to first training' };
  } catch (error) {
    console.error('Error matching feedback to training:', error);
    return { rank: 1, training: null, reasoning: 'Error in AI matching' };
  }
}

