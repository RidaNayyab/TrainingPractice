// DEBUG: Analyze training recommendation for a teacher
app.get('/api/debug/training-recommendation/:teacherId/:indicatorCode', async (req: Request, res: Response) => {
  try {
    const { teacherId, indicatorCode } = req.params;

    // Get teacher feedback
    const feedbackResult = await dbClient.query(
      `SELECT ofl.feedback_english, o.teacher_id, o.created_at
       FROM observation_feedback_loops ofl
       JOIN observations o ON ofl.observation_id = o.id
       WHERE o.teacher_id = $1
       ORDER BY o.created_at DESC
       LIMIT 1`,
      [teacherId]
    );

    if (feedbackResult.rows.length === 0) {
      return res.json({
        teacherId,
        indicatorCode,
        feedback: 'No feedback found',
        recommendedTraining: null,
        analysis: 'No observations found for this teacher'
      });
    }

    const feedback = feedbackResult.rows[0].feedback_english;
    const training = trainingsData[indicatorCode as keyof typeof trainingsData];

    if (!training) {
      return res.json({ error: 'Indicator not found' });
    }

    console.log(`\n📊 ANALYZING TEACHER ${teacherId} - ${indicatorCode}`);
    console.log(`Feedback: "${feedback.substring(0, 100)}..."`);

    const trainingOptions = training.resources.map((resource: any, index: number) =>
      `${index}. ${resource.title}: ${resource.rationale}`
    ).join('\n');

    const message = await anthropic.messages.create({
      model: 'claude-opus-4-7',
      max_tokens: 1000,
      messages: [
        {
          role: 'user',
          content: `Analyze this teacher feedback and recommend training. Explain your reasoning.

Teacher Feedback: "${feedback}"

Available trainings for ${indicatorCode} (in progression order):
${trainingOptions}

Respond in JSON:
{
  "rootCause": "What is the actual problem?",
  "recommendedIndex": 0-${training.resources.length - 1},
  "reasoning": "Why this training?"
}`
        }
      ]
    });

    const response = message.content[0];
    if (response.type === 'text') {
      try {
        const analysis = JSON.parse(response.text);
        console.log(`✨ Recommendation: Training ${analysis.recommendedIndex} - ${training.resources[analysis.recommendedIndex].title}`);
        console.log(`   Reasoning: ${analysis.reasoning}\n`);

        return res.json({
          teacherId,
          indicatorCode,
          feedback: feedback.substring(0, 200),
          rootCause: analysis.rootCause,
          recommendedIndex: analysis.recommendedIndex,
          recommendedTraining: training.resources[analysis.recommendedIndex].title,
          reasoning: analysis.reasoning,
          allTrainings: training.resources.map((t, i) => ({ index: i, title: t.title }))
        });
      } catch {
        return res.json({ error: 'Failed to parse AI response', response: response.text });
      }
    }

    return res.json({ error: 'Unexpected response format' });
  } catch (error: any) {
    console.error('Debug error:', error);
    res.status(500).json({ error: error.message });
  }
});

