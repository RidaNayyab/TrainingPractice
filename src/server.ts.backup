const SONIOX_API_BASE_URL = 'https://api.soniox.com';

// Analyze feedback and recommend the best training
async function recommendTraining(indicatorCode: string, feedback: string): Promise<number> {
  try {
    const trainings = trainingsData[indicatorCode as keyof typeof trainingsData];

    if (!trainings || trainings.resources.length === 0) {
      return 0;
    }

    const trainingOptions = trainings.resources.map((resource: any, index: number) =>
      `${index}. ${resource.title}: ${resource.rationale}`
    ).join('\n');

    const message = await anthropic.messages.create({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 500,
      messages: [
        {
          role: 'user',
          content: `Based on this teacher feedback, recommend the BEST training to address the root issue.

Indicator: ${indicatorCode}
Teacher Feedback: "${feedback}"

Available trainings (in order of progression):
${trainingOptions}

Respond with ONLY the number (0-${trainings.resources.length - 1}) of the best training. For example: 0 or 1 or 2

Think about:
- What is the ROOT CAUSE of the issue?
- Which training directly addresses that root cause?
- Pick the EARLIEST/FOUNDATIONAL training that fixes the core problem`
        }
      ]
    });

    const response = message.content[0];
    if (response.type === 'text') {
      const match = response.text.match(/\d+/);
      const index = match ? parseInt(match[0]) : 0;
      return Math.min(Math.max(index, 0), trainings.resources.length - 1);
    }

    return 0;
  } catch (error) {
    console.error('Error recommending training:', error);
    return 0;
  }
}

// Upload audio file to Soniox
app.post('/api/upload-audio', (req: any, res: any) => {
  const audioBuffer = req.body;
  const bufferLen = audioBuffer?.length || 0;
  const bufferType = audioBuffer?.constructor?.name;

  if (!audioBuffer || bufferLen === 0) {
    return res.status(400).json({
      error: 'No audio provided',
      debug: { bufferLen, bufferType, contentType: req.headers['content-type'] }
    });
  }

  (async () => {
  try {

    const apiKey = process.env.SONIOX_API_KEY;
    if (!apiKey) {
      return res.status(500).json({ error: 'Soniox API key not configured' });
    }

    console.log('📤 Uploading audio to Soniox, size:', audioBuffer.length, 'bytes');

    const form = new FormData();
    form.append('file', new Blob([new Uint8Array(audioBuffer as any)]), 'audio.webm');

    const response = await fetch(`${SONIOX_API_BASE_URL}/v1/files`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${apiKey}`,
      },
      body: form as any,
    });

    if (!response.ok) {
      const error = await response.text();
      console.error('❌ Soniox upload error:', response.status, error);
      return res.status(response.status).json({ error: 'Upload failed: ' + error });
    }

    const result = await response.json();
    const fileId = result.id;
    console.log('✅ File uploaded, ID:', fileId);

    res.json({ fileId });
  } catch (error: any) {
    console.error('❌ Upload error:', error);
    res.status(500).json({ error: error.message });
  }
  })();
});

// Create transcription job
app.post('/api/transcribe', async (req: any, res: any) => {
  try {
    const { fileId } = req.body;

    if (!fileId) {
      return res.status(400).json({ error: 'File ID is required' });
    }

    const apiKey = process.env.SONIOX_API_KEY;
    if (!apiKey) {
      return res.status(500).json({ error: 'Soniox API key not configured' });
    }

    console.log('📝 Creating transcription job for file:', fileId);

    const config = {
      model: 'stt-async-v4',
      file_id: fileId,
      language_hints: ['en', 'es', 'ur'],
      enable_language_identification: true,
      enable_speaker_diarization: true,
    };

    const response = await fetch(`${SONIOX_API_BASE_URL}/v1/transcriptions`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(config),
    });

    if (!response.ok) {
      const error = await response.text();
      console.error('❌ Soniox error:', response.status, error);
      return res.status(response.status).json({ error: 'Transcription creation failed: ' + error });
    }

    const result = await response.json();
    const transcriptionId = result.id;
    console.log('✅ Transcription job created, ID:', transcriptionId);

    res.json({ transcriptionId });
  } catch (error: any) {
    console.error('❌ Transcription error:', error);
    res.status(500).json({ error: error.message });
  }
});

