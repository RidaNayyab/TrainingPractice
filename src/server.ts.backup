// Handle database connection errors with auto-reconnect
dbClient.on('error', (err: Error) => {
  console.error('❌ Database connection error:', err);
  console.log('⏳ Attempting to reconnect...');
  setTimeout(() => {
    dbClient.connect().catch(e => console.error('Reconnection failed:', e));
  }, 3000);
});

// Connect to database and start server
dbClient.connect().then(async () => {
  console.log('✅ Connected to database');

  // Load all observations into cache
  try {
    console.log('📥 Loading observations into cache...');
    const result = await dbClient.query(`
      SELECT
        o.id, o.teacher_id, o.transcription,
        o.subject, o.grade, o.region, o.rubric_type,
        o.created_at,
        (SELECT feedback_english FROM observation_feedback_loops
         WHERE observation_id = o.id LIMIT 1) as feedback_english,
        (SELECT improvement_areas FROM observation_feedback_loops
         WHERE observation_id = o.id LIMIT 1) as improvement_areas
      FROM observations o
      ORDER BY o.teacher_id, o.created_at DESC
    `);
    observationsCache = result.rows;
    cacheLoaded = true;
    console.log(`✅ Loaded ${observationsCache.length} observations into cache`);
  } catch (err) {
    console.error('⚠️ Error loading observations:', err);
  }

  // Create completed_trainings table if it doesn't exist
  try {
    await dbClient.query(`
      CREATE TABLE IF NOT EXISTS completed_trainings (
        id SERIAL PRIMARY KEY,
        teacher_id INTEGER NOT NULL,
        indicator_code VARCHAR(50) NOT NULL,
        resource_index INTEGER NOT NULL,
        completed_at TIMESTAMP DEFAULT NOW(),
        UNIQUE(teacher_id, indicator_code, resource_index)
      )
    `);
    console.log('✅ Completed trainings table ready');
  } catch (err) {
    console.error('⚠️ Error creating table:', err);
  }

  app.listen(PORT, () => {
    console.log(`🚀 Server running on http://localhost:${PORT}`);
  });
}).catch((err: Error) => {
  console.error('❌ Database connection failed:', err);
  process.exit(1);
});
