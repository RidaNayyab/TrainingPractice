// Evaluate practice response
app.post('/api/evaluate', async (req: Request, res: Response) => {
  try {
    const { response, questionId } = req.body;

    if (!response || response.trim().length < 20) {
      return res.status(400).json({ error: 'Response must be at least 20 characters' });
    }

    if (!questionId) {
      return res.status(400).json({ error: 'Question ID is required' });
    }

    let evaluation: any = {};

    if (questionId === 'PQ_SI1_01') {
      // Math opening: Strict evaluation of learning goal
      // Must have clear goal statement AND be substantial (not just 1-2 words)
      const hasGoalStatement = /today\s+we\s+(will\s+)?learn|learning\s+(goal|objective)|are\s+going\s+to\s+learn/i.test(response);
      const isSubstantial = response.length > 30; // Must be more than just "today we will learn"

      const goalMatch = response.match(/(?:today\s+we\s+(?:will\s+)?learn|learning\s+(?:goal|objective)|are\s+going\s+to\s+learn)[^.!?]*/i);
      const extractedGoal = goalMatch ? goalMatch[0].trim() : '';

      const score = (hasGoalStatement && isSubstantial) ? 'YES' : 'NO';

      evaluation = {
        score,
        evidence: score === 'YES'
          ? `Clear learning goal with substantive explanation: "${extractedGoal}"`
          : hasGoalStatement
          ? 'Goal statement is present but too brief. Expand on what students will specifically learn and why.'
          : 'No clear learning goal or objective statement found in the opening',
        what_worked: score === 'YES' ? ['Clear goal statement', 'Substantial explanation'] : [],
        what_to_improve: score === 'NO'
          ? ['State clearly what students will learn today', 'Make the goal specific and measurable', 'Provide enough detail and explanation']
          : [],
        rubric_criteria_met: score === 'YES' ? ['Clear Learning Goal'] : [],
        rubric_criteria_missed: score === 'YES' ? [] : ['Clear Learning Goal'],
        rubric_criteria_not_applicable: [],
      };
    } else if (questionId === 'PQ_SI1_02') {
      // Explanation: Strict evaluation - need BOTH clear definition AND multiple connector words
      const hasDetailedDefinition = /(?:main\s+idea\s+(?:is|means|refers to|can be defined as))|(?:the\s+(?:main\s+)?idea\s+(?:is|means|refers to|can be defined as))/i.test(response);
      const connectorCount = (response.match(/\b(first|next|then|because|therefore|so|for\s+example|finally|in\s+conclusion|additionally|furthermore|moreover)\b/gi) || []).length;
      const hasMultipleConnectors = connectorCount >= 2;
      const isSubstantial = response.length > 50;

      const score = (hasDetailedDefinition && hasMultipleConnectors && isSubstantial) ? 'YES'
            : (hasDetailedDefinition || hasMultipleConnectors) && isSubstantial ? 'PARTIAL'
            : 'NO';

      evaluation = {
        score,
        evidence: score === 'YES'
          ? 'Excellent: Clear definition with well-structured step-by-step explanation using connector words.'
          : score === 'PARTIAL'
          ? 'Partial: You have some of the elements, but need both a clear definition AND multiple sequential steps with connector words.'
          : 'Needs work: Response lacks clear definition or step-by-step explanation with connectors. Be more detailed and structured.',
        what_worked: score !== 'NO' ? ['Attempted explanation'] : [],
        what_to_improve: score === 'YES'
          ? []
          : [
              'Provide a clear definition of "main idea" (e.g., "Main idea means...")',
              'Explain the process step-by-step using connector words (first, next, then, because, finally, etc.)',
              'Give specific examples students can follow'
            ],
        rubric_criteria_met: [],
        rubric_criteria_missed: [],
        rubric_criteria_not_applicable: [],
      };
    } else {
      return res.status(400).json({ error: 'Unknown question ID' });
    }

    res.json(evaluation);
  } catch (error: any) {
    console.error('Error evaluating response:', error);
    res.status(500).json({ error: error.message });
  }
});

// Mark training as completed
app.post('/api/training/complete', async (req: Request, res: Response) => {
  try {
    const { teacherId, indicatorCode, resourceIndex } = req.body;

    if (!teacherId || !indicatorCode || resourceIndex === undefined) {
      return res.status(400).json({ error: 'Missing required fields' });
    }

    // Check if already marked as complete
    const existing = await dbClient.query(
      `SELECT id FROM completed_trainings
       WHERE teacher_id = $1 AND indicator_code = $2 AND resource_index = $3`,
      [teacherId, indicatorCode, resourceIndex]
    );

    if (existing.rows.length > 0) {
      return res.json({ success: true, message: 'Already marked complete' });
    }

    // Insert completion record
    await dbClient.query(
      `INSERT INTO completed_trainings (teacher_id, indicator_code, resource_index, completed_at)
       VALUES ($1, $2, $3, NOW())
       ON CONFLICT DO NOTHING`,
      [teacherId, indicatorCode, resourceIndex]
    );

    res.json({ success: true, message: 'Training marked as completed' });
  } catch (error: any) {
    console.error('Error marking training as complete:', error);
    res.status(500).json({ error: error.message });
  }
});

